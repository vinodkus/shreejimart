# Copy to backend/ShreeJiMart.Api/.env (gitignored) or set in VS Debug environment variables.
# Do NOT commit real passwords.

# Neon (recommended) — paste your full connection string from Neon dashboard:
DATABASE_URL=postgresql://USER:PASSWORD@HOST/neondb?sslmode=require

# Or local PostgreSQL (alternative):
# POSTGRES_HOST=localhost
# POSTGRES_PORT=5432
# POSTGRES_DB=ShreejiMart
# POSTGRES_USER=postgres
# POSTGRES_PASSWORD=change_me
# POSTGRES_SSLMODE=Prefer

ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin123

# Comma or semicolon separated UI origins (required for browser API calls)
CORS_ORIGINS=https://test.sanatini.com;http://localhost:4200
